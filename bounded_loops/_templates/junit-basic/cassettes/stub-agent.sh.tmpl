#!/usr/bin/env bash
# cassettes/stub-agent.sh — used only by the standalone run.sh/wreck.sh
# scripts (NOT by `bl run`, which uses cassettes/default.json directly via
# the stub runner adapter). Writes the fixed Example.java to the CURRENT
# directory (cwd = seed/ — run.sh/wreck.sh both `cd "$SEED_DIR"` before
# invoking $AGENT_CLI), matching lap 1 of default.json, so the standalone
# scripts have a keyless "agent" to drive against without any API key.
set -euo pipefail

cat > Example.java <<'JAVA'
public class Example {
    /** Add two integers. */
    public static int add(int a, int b) {
        return a + b;
    }
}
JAVA

echo "stub-agent: wrote Example.java"
