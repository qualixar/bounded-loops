#!/usr/bin/env bash
# cassettes/stub-agent.sh — used only by the standalone run.sh/wreck.sh
# scripts (NOT by `bl run`, which uses cassettes/default.json directly via
# the stub runner adapter). Writes the fixed lib.rs to CURRENT/src/lib.rs
# (cwd = seed/ — run.sh/wreck.sh both `cd "$SEED_DIR"` before invoking
# $AGENT_CLI), matching lap 1 of default.json, so the standalone scripts
# have a keyless "agent" to drive against without any API key.
set -euo pipefail

cat > src/lib.rs <<'RS'
pub fn add(a: i32, b: i32) -> i32 {
    a + b
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_positive() {
        assert_eq!(add(2, 3), 5);
    }

    #[test]
    fn test_negative() {
        assert_eq!(add(-1, -1), -2);
    }

    #[test]
    fn test_zero() {
        assert_eq!(add(0, 0), 0);
    }
}
RS

echo "stub-agent: wrote src/lib.rs"
