#!/usr/bin/env bash
# wreck.sh — the UNGATED version of {{LOOP_NAME}}. Same spec, no independent
# gate. Demonstrates why a gate matters: without one, the loop trusts
# whatever the agent claims, even if the underlying bug is still present.
#
# Requirements: bash 3.2+, Ruby, RSpec (used only by the diagnostic epilogue
# below — the wrecked loop itself never calls rspec, that's the point).

set -euo pipefail

# Defensive PATH fix: if rspec was installed via `gem install --user-install
# rspec` (common when the system gem dir isn't writable), its binary lives
# in the user gem dir, not on the default PATH. Adding it here means this
# script works without requiring a permanent shell-profile edit.
export PATH="$PATH:$(ruby -e 'puts Gem.user_dir')/bin"

LOOP_DIR="$(cd "$(dirname "$0")" && pwd)"
SEED_DIR="$LOOP_DIR/seed"
MAX_ITER=10

if ! command -v rspec >/dev/null 2>&1; then
    echo "error: 'rspec' not found on PATH." >&2
    echo "       Install it first: gem install rspec" >&2
    echo "       (or: gem install --user-install rspec, then re-run this script)" >&2
    exit 2
fi

AGENT_CLI="${AGENT_CLI:-bash $LOOP_DIR/cassettes/stub-agent.sh}"

echo "=== {{LOOP_NAME}} — WRECKED (no gate) ==="
echo "WARNING: this loop trusts the agent's own claim — it never checks rspec."
echo ""

i=0
cd "$SEED_DIR"

while [ "$i" -lt "$MAX_ITER" ]; do
    i=$((i + 1))
    echo "--- Lap $i (no gate) ---"
    $AGENT_CLI < "$LOOP_DIR/PROMPT.md"
    echo "(no gate check here — this is the point)"
done

echo ""
echo "--- Diagnostic epilogue (NOT part of the wrecked loop's own logic) ---"
if rspec_output="$(rspec 2>&1)"; then
    echo "rspec actually passes — the fix happened to land anyway."
    exit 0
else
    echo "The ungated loop ran to completion with no gate ever checking the result."
    echo "$rspec_output"
    exit 1
fi
