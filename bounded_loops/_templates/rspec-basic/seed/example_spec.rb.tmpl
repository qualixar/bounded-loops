require_relative 'example'

RSpec.describe '#add' do
  it 'adds two positive integers' do
    expect(add(2, 3)).to eq(5)
  end

  it 'adds two negative integers' do
    expect(add(-1, -1)).to eq(-2)
  end

  it 'adds zero' do
    expect(add(0, 0)).to eq(0)
  end
end
