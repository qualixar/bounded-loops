{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sub-agent configuration",
  "description": "Required shape for an authored sub-agent config before it may be registered.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["Read", "Write", "Edit", "Bash", "Grep", "Glob"]
      }
    },
    "model": {
      "type": "string",
      "enum": ["sonnet", "opus", "haiku"]
    }
  },
  "required": ["name", "description", "tools", "model"],
  "additionalProperties": false
}
