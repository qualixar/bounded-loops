{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserRecord",
  "description": "API response contract for a single user record.",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique numeric user id."
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User's email address."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of account creation."
    },
    "role": {
      "type": "string",
      "enum": ["admin", "member", "viewer"],
      "description": "User's role within the system."
    }
  },
  "required": ["id", "email", "created_at", "role"],
  "additionalProperties": false
}
